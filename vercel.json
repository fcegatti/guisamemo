{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/(es|gl)/(.*)", "destination": "/index.html" },
    { "source": "/(es|gl)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/manifest.webmanifest", "dest": "/manifest.webmanifest", "status": 200 },
    { "src": "/(es|gl)/manifest.webmanifest", "dest": "/manifest.webmanifest", "status": 200 },
    { "src": "/(.*)\\.(js|css|webp|png|jpg|svg|ico|json|mp3|ogg)", "dest": "/$1.$2", "status": 200 },
    { "src": "/(.*)", "dest": "/index.html", "status": 200 }
  ]
}